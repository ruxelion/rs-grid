{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "docs": {
      "type": "http",
      "url": "https://mcp.benoitpodwinski.com/mcp"
    },
    "openai-docs": {
      "type": "http",
      "url": "https://developers.openai.com/mcp"
    },
    "ag-grid": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "ag-mcp@1.0.0",
        "-p",
        "ajv",
        "ag-mcp"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "${USERPROFILE}/.claude/bin/github-mcp-server.exe",
      "args": [
        "stdio"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}