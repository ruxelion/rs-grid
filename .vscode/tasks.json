{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "just: check",
      "type": "shell",
      "command": "just check",
      "group": "build",
      "problemMatcher": ["$rustc"],
      "detail": "cargo check --workspace"
    },
    {
      "label": "just: build",
      "type": "shell",
      "command": "just build",
      "group": "build",
      "problemMatcher": ["$rustc"],
      "detail": "cargo build -p rs-grid-core"
    },
    {
      "label": "just: test",
      "type": "shell",
      "command": "just test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"],
      "detail": "cargo nextest run --workspace (WASM crates excluded)"
    },
    {
      "label": "just: test-core",
      "type": "shell",
      "command": "just test-core",
      "group": "test",
      "problemMatcher": ["$rustc"],
      "detail": "cargo nextest run -p rs-grid-core"
    },
    {
      "label": "just: coverage",
      "type": "shell",
      "command": "just coverage",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo llvm-cov nextest --ignore-filename-regex generate_theme (HTML)"
    },
    {
      "label": "just: coverage-lcov",
      "type": "shell",
      "command": "just coverage-lcov",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo llvm-cov nextest --ignore-filename-regex generate_theme → lcov.info"
    },
    {
      "label": "just: fmt",
      "type": "shell",
      "command": "just fmt",
      "problemMatcher": [],
      "detail": "cargo fmt --all"
    },
    {
      "label": "just: lint",
      "type": "shell",
      "command": "just lint",
      "group": "build",
      "problemMatcher": ["$rustc"],
      "detail": "cargo clippy --workspace -- -D warnings"
    },
    {
      "label": "just: ci",
      "type": "shell",
      "command": "just ci",
      "group": "build",
      "problemMatcher": ["$rustc"],
      "detail": "fmt + lint + test"
    },
    {
      "label": "just: build-wasm",
      "type": "shell",
      "command": "just build-wasm ${input:example}",
      "group": "build",
      "problemMatcher": [],
      "detail": "Build WASM d'un exemple"
    },
    {
      "label": "just: serve",
      "type": "shell",
      "command": "just serve ${input:example}",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Serveur de dev d'un exemple"
    },
    {
      "label": "just: tls-setup",
      "type": "shell",
      "command": "just tls-setup",
      "problemMatcher": [],
      "detail": "Générer les certificats TLS locaux (mkcert requis)"
    },
    {
      "label": "just: e2e-install",
      "type": "shell",
      "command": "just e2e-install",
      "problemMatcher": [],
      "detail": "Installer Playwright + Chromium"
    },
    {
      "label": "just: e2e",
      "type": "shell",
      "command": "just e2e",
      "group": "test",
      "problemMatcher": [],
      "detail": "Build Leptos + tests Playwright"
    },
    {
      "label": "just: e2e-update-snapshots",
      "type": "shell",
      "command": "just e2e-update-snapshots",
      "problemMatcher": [],
      "detail": "Regénérer screenshots de référence"
    },
    {
      "label": "just: build-site-wasm",
      "type": "shell",
      "command": "just build-site-wasm",
      "group": "build",
      "problemMatcher": [],
      "detail": "Build WASM demo + copie dans le site"
    },
    {
      "label": "just: site",
      "type": "shell",
      "command": "just site",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "RSPress dev server (port 5173)"
    },
    {
      "label": "just: build-site",
      "type": "shell",
      "command": "just build-site",
      "group": "build",
      "problemMatcher": [],
      "detail": "Build site RSPress (avec démo WASM)"
    },
    {
      "label": "just: bench",
      "type": "shell",
      "command": "just bench",
      "group": "test",
      "problemMatcher": [],
      "detail": "Tous les benchmarks (core + scene) — rapports HTML dans target/criterion/"
    },
    {
      "label": "just: bench-core",
      "type": "shell",
      "command": "just bench-core",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo bench -p rs-grid-core (hit-test + tri + filtre)"
    },
    {
      "label": "just: bench-hit",
      "type": "shell",
      "command": "just bench-hit",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo bench --bench hit_test (cell, col_header, with_scroll)"
    },
    {
      "label": "just: bench-sort",
      "type": "shell",
      "command": "just bench-sort",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo bench --bench sort (numeric cold/cached, string cold/cached, filter)"
    },
    {
      "label": "just: bench-scene",
      "type": "shell",
      "command": "just bench-scene",
      "group": "test",
      "problemMatcher": [],
      "detail": "cargo bench --bench scene_builder (small/medium/dense, DPR 1 et 2)"
    },
    {
      "label": "just: mcp-build",
      "type": "shell",
      "command": "just mcp-build",
      "group": "build",
      "problemMatcher": [],
      "detail": "Build site + MCP (TypeScript → dist/ + copie docs)"
    },
    {
      "label": "just: mcp-dev",
      "type": "shell",
      "command": "just mcp-dev",
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Serveur MCP en mode développement (tsx)"
    },
    {
      "label": "just: mcp-publish",
      "type": "shell",
      "command": "just mcp-publish",
      "problemMatcher": [],
      "detail": "Publier rs-grid-mcp sur npm (nécessite npm login)"
    }
  ],
  "inputs": [
    {
      "id": "example",
      "type": "pickString",
      "description": "Exemple à lancer",
      "options": ["leptos", "dioxus", "yew", "js", "react"],
      "default": "leptos"
    }
  ]
}
