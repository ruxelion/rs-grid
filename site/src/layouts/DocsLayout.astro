---
import Base from './Base.astro';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { title, description, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title ?? title;
const pageDesc = frontmatter?.description ?? description;
const currentPath = Astro.url.pathname;

const navGroups = [
  {
    label: 'Getting started',
    items: [
      { href: '/docs', label: 'Overview' },
      { href: '/docs/getting-started', label: 'Installation' },
      { href: '/docs/leptos', label: 'Leptos integration' },
    ],
  },
  {
    label: 'Core concepts',
    items: [
      { href: '/docs/architecture', label: 'Architecture' },
      { href: '/docs/viewport', label: 'Viewport' },
      { href: '/docs/selection', label: 'Selection' },
    ],
  },
  {
    label: 'Deployment',
    items: [
      { href: '/docs/docker', label: 'Docker' },
    ],
  },
];
---

<Base title={pageTitle} description={pageDesc}>
  <div class="docs-page">
    <aside class="docs-sidebar">
      <nav>
        {navGroups.map(group => (
          <div class="nav-group">
            <span class="nav-group-label">{group.label}</span>
            <ul>
              {group.items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class={currentPath === item.href ? 'active' : ''}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>
    <div class="docs-content">
      <slot />
    </div>
  </div>
</Base>

<style is:global>
  .docs-page {
    display: grid;
    grid-template-columns: 240px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 64px);
  }

  .docs-sidebar {
    border-right: 1px solid var(--border);
    padding: 2rem 1rem;
    position: sticky;
    top: 64px;
    height: calc(100vh - 64px);
    overflow-y: auto;
  }

  .nav-group {
    margin-bottom: 1.75rem;
  }

  .nav-group-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    margin-bottom: 0.375rem;
    padding: 0 0.5rem;
  }

  .docs-sidebar ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .docs-sidebar a {
    display: block;
    padding: 0.375rem 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .docs-sidebar a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .docs-sidebar a.active {
    color: var(--primary);
    background: var(--primary-light);
  }

  .docs-content {
    padding: 2.5rem 3rem;
    min-width: 0;
    max-width: 800px;
  }

  .docs-content h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text);
    line-height: 1.2;
  }

  .docs-content .lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    line-height: 1.7;
  }

  .docs-content h2 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
    color: var(--text);
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .docs-content h2:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .docs-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .docs-content p {
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .docs-content ul,
  .docs-content ol {
    color: var(--text-muted);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  .docs-content li {
    margin-bottom: 0.25rem;
  }

  .docs-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .docs-content th {
    text-align: left;
    padding: 0.625rem 1rem;
    font-weight: 600;
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid var(--border-strong);
    border-top: 1px solid var(--border);
  }

  .docs-content td {
    padding: 0.625rem 1rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .docs-content .callout {
    background: var(--primary-light);
    border: 1px solid var(--primary-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .docs-content .callout strong {
    color: var(--text);
  }
</style>
