---
import { getLangFromUrl, t, localePath, switchLangPath } from '../i18n/utils';
import { languages } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  fullBleed?: boolean;
}

const {
  title = "rs-grid",
  description = "High-performance Rust/WASM data grid engine for the web",
  fullBleed = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const switchPath = switchLangPath(Astro.url);
const altLang = lang === 'en' ? 'fr' : 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === "rs-grid" ? "rs-grid" : `${title} — rs-grid`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header id="site-header">
      <nav>
        <a href={localePath(lang, '/')} class="logo">
          <span class="logo-accent">rs</span>-grid
        </a>
        <ul class="nav-links">
          <li>
            <a href={localePath(lang, '/')} class:list={[{ active: currentPath === localePath(lang, '/') }]}>{t(lang, 'nav.home')}</a>
          </li>
          <li>
            <a
              href={localePath(lang, '/docs')}
              class:list={[{ active: currentPath.startsWith(localePath(lang, '/docs')) }]}>{t(lang, 'nav.docs')}</a
            >
          </li>
        </ul>
        <div class="nav-cta">
          <a href={switchPath} class="btn-lang">{languages[altLang]}</a>
          <a
            href="https://github.com/bpodwinski/rs-grid"
            target="_blank"
            rel="noopener"
            class="btn-outline-sm"
          >
            GitHub ↗
          </a>
          <a href={localePath(lang, '/docs')} class="btn-primary-sm">{t(lang, 'nav.getStarted')}</a>
        </div>
      </nav>
    </header>

    <main class:list={[{ "no-pad": fullBleed }]}>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="logo-accent">rs</span>-grid
          <p>{t(lang, 'footer.desc')}</p>
        </div>
        <div class="footer-links">
          <div>
            <h4>{t(lang, 'footer.project')}</h4>
            <ul>
              <li><a href={localePath(lang, '/docs')}>{t(lang, 'footer.documentation')}</a></li>
              <li>
                <a
                  href="https://github.com/bpodwinski/rs-grid"
                  target="_blank"
                  rel="noopener">GitHub</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4>{t(lang, 'footer.stack')}</h4>
            <ul>
              <li>
                <a
                  href="https://www.rust-lang.org"
                  target="_blank"
                  rel="noopener">Rust</a
                >
              </li>
              <li>
                <a href="https://webassembly.org" target="_blank" rel="noopener"
                  >WebAssembly</a
                >
              </li>
              <li>
                <a href="https://leptos.dev" target="_blank" rel="noopener"
                  >Leptos</a
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t(lang, 'footer.copyright')}</p>
      </div>
    </footer>

    <script>
      // Sticky header shadow on scroll
      const header = document.getElementById("site-header");
      window.addEventListener("scroll", () => {
        header?.classList.toggle("scrolled", window.scrollY > 10);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --primary: #3b82f6;
    --primary-hover: #2563eb;
    --primary-light: rgba(59, 130, 246, 0.1);
    --primary-border: rgba(59, 130, 246, 0.3);

    --bg: #0a0f1e;
    --bg-surface: #0f1629;
    --bg-card: #111827;
    --bg-card-hover: #1a2436;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.14);

    --text: #f9fafb;
    --text-muted: #9ca3af;
    --text-subtle: #6b7280;

    --font: "Inter", system-ui, -apple-system, sans-serif;
    --font-mono: "Cascadia Code", "Fira Code", monospace;

    --radius: 12px;
    --radius-sm: 8px;
    --radius-lg: 16px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--primary);
    text-decoration: none;
    transition: color 0.15s;
  }

  a:hover {
    color: var(--primary-hover);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(59, 130, 246, 0.1);
    color: #93c5fd;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  pre {
    background: #0d1117;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    color: #e2e8f0;
    font-size: 1em;
  }

  /* ── Header ── */
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 15, 30, 0);
    border-bottom: 1px solid transparent;
    transition:
      transparent 0.2s,
      background 0.2s;
  }

  #site-header.scrolled {
    background: rgba(10, 15, 30, 0.7);
    border-bottom-color: var(--border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--text);
  }

  .logo-accent {
    color: var(--primary);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-links a {
    display: block;
    padding: 0.4rem 0.875rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    transition:
      color 0.15s,
      background 0.15s;
    text-decoration: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .btn-lang {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-subtle);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: color 0.15s, border-color 0.15s;
    text-decoration: none;
  }

  .btn-lang:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  .btn-outline-sm {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    transition:
      color 0.15s,
      border-color 0.15s;
    text-decoration: none;
  }

  .btn-outline-sm:hover {
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .btn-primary-sm {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background: var(--primary);
    padding: 0.4rem 1.125rem;
    border-radius: var(--radius-sm);
    transition:
      background 0.15s,
      transform 0.1s;
    text-decoration: none;
  }

  .btn-primary-sm:hover {
    background: var(--primary-hover);
    color: #fff;
  }

  /* ── Main ── */
  main {
    flex: 1;
    padding-top: 64px;
  }

  main.no-pad {
    padding-top: 0;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    gap: 4rem;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .footer-brand {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .footer-brand p {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-subtle);
  }

  .footer-links {
    display: flex;
    gap: 3rem;
  }

  .footer-links h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    margin-bottom: 0.875rem;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 1.25rem 2rem;
    text-align: center;
    color: var(--text-subtle);
    font-size: 0.8rem;
  }
</style>
