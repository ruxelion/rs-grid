{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(wasm-pack build:*)",
      "Bash(trunk build:*)",
      "Bash(trunk serve:*)",
      "Bash(taskkill:*)",
      "Bash(nohup trunk:*)",
      "Bash(trunk --version)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npx playwright:*)",
      "Bash(npx serve:*)",
      "Bash(grep -A1 'name = \"\"\"\"send_wrapper\"\"\"\"')",
      "Bash(grep -A2 'name = \"\"\"\"send_wrapper\"\"\"\"' D:/Dev/rs-grid/Cargo.lock)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 15,
            "command": "input=$(cat); echo \"$input\" | grep -qE '\\.(rs|toml|css|html)\"' && (taskkill //F //IM trunk.exe 2>/dev/null; sleep 1; cd /c/Dev/rs-grid/examples/basic-leptos && nohup trunk serve >/tmp/trunk.log 2>&1 &) || true"
          }
        ]
      }
    ]
  }
}
